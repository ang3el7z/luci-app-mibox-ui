msgstr "Automatic Interface Detection"

msgid "Automatically detect WAN interface"
msgstr "Automatically detect WAN interface"

msgid "When enabled, automatically detects and excludes WAN interface. Disable for manual interface exclusions."
msgstr "When enabled, automatically detects and excludes WAN interface. Disable for manual interface exclusions."

