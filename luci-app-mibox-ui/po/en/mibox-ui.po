msgstr "Select interfaces to process"

msgid "Select interfaces to exclude"
msgstr "Select interfaces to exclude"

msgid "Traffic from these interfaces will be processed by the proxy."
msgstr "Traffic from these interfaces will be processed by the proxy."

msgid "Traffic from these interfaces will bypass the proxy (direct routing)."
msgstr "Traffic from these interfaces will bypass the proxy (direct routing)."

msgid "Additional Settings"
msgstr "Additional Settings"

msgid "Block QUIC traffic (UDP port 443)"
msgstr "Block QUIC traffic (UDP port 443)"

msgid "When enabled, blocks QUIC traffic on UDP port 443. This can improve proxy effectiveness for services like YouTube."
msgstr "When enabled, blocks QUIC traffic on UDP port 443. This can improve proxy effectiveness for services like YouTube."

msgid "Store rules and proxy providers in RAM (tmpfs)"
msgstr "Store rules and proxy providers in RAM (tmpfs)"

msgid "When enabled, rulesets and proxy-providers are stored in tmpfs for faster access (uses RAM)."
msgstr "When enabled, rulesets and proxy-providers are stored in tmpfs for faster access (uses RAM)."

msgid "Add HWID headers to subscriptions"
msgstr "Add HWID headers to subscriptions"

msgid "Automatically adds HWID headers to proxy-providers for device tracking (Remnawave compatibility)."
msgstr "Automatically adds HWID headers to proxy-providers for device tracking (Remnawave compatibility)."

